{
  "device": {
    "uid": "",
    "parent_id": "GATEWAY_PI",
    "send_interval": 60
  },

  "lora": {
    "frequency": 433.1,
    "spreading_factor": 10,
    "bandwidth": 500000,
    "coding_rate": 5,
    "tx_power": 14,
    "preamble_length": 8,
    "crc": true,
    "spi_baudrate": 5000000,
    "max_retries": 2,
    "listen_timeout_ms": 2000,
    "pins": {
      "sck": 18,
      "miso": 19,
      "mosi": 23,
      "cs": 5,
      "rst": 14,
      "dio0": 26
    }
  },

  "i2c": {
    "id": 0,
    "sda": 21,
    "scl": 22,
    "freq": 400000
  },

  "sensors": [
    {
      "type": "dht22",
      "name": "air",
      "enabled": true,
      "pin": 26,
      "codes": { "temperature": "TA", "humidity": "HA" },
      "index": 1,
      "retry": 3,
      "delay_ms": 2000,
      "alerts": {}
    },
    {
      "type": "ds18b20",
      "name": "sol_temp",
      "enabled": true,
      "pin": 14,
      "codes": { "temperature": "TS" },
      "index": 1,
      "alerts": {}
    },
    {
      "type": "bh1750",
      "name": "luminosity",
      "enabled": true,
      "bus": "i2c",
      "codes": { "luminosity": "L" },
      "index": 1,
      "alerts": {}
    },
    {
      "type": "lm393",
      "name": "sol_humidity",
      "enabled": true,
      "pin": 35,
      "codes": { "soil_moisture": "HS" },
      "index": 1,
      "params": {
        "dry_value": 3500,
        "wet_value": 900
      },
      "alerts": {}
    },
    {
      "type": "lm393",
      "name": "sol_humidity",
      "enabled": true,
      "pin": 36,
      "index": 2,
      "codes": { "soil_moisture": "HS" },
      "params": {
        "dry_value": 3500,
        "wet_value": 900
      },
      "alerts": {}
    }
  ],

  "communication": {
    "ack_wait_ms": 2000,
    "gateway_receive_timeout_ms": 10000
  },

  "pairing": {
    "timeout_ms": 3000
  },

  "button": {
    "pin": 4,
    "pin_led": 32
  },

  "power": {
    "sleep_interval": 15,
    "reset_duration_ms": 10000,
    "micro_sleep_ms": 1000,
    "listen_timeout_ms": 100
  },

  "alert": {
    "alert_timeout": 86400
  }
}

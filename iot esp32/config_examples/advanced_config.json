{
  "device": {
    "uid": "ESP32-SMART-FARM",
    "send_interval": 300,
    "listen_timeout": 10000,
    "debug_mode": true,
    "deep_sleep_enabled": false
  },
  
  "lora": {
    "frequency": 868.0,
    "spreading_factor": 10,
    "bandwidth": 125000,
    "coding_rate": 5,
    "tx_power": 14,
    "sync_word": "0x12",
    "preamble_length": 8,
    "crc": true,
    "implicit_header": false
  },
  
  "communication": {
    "type": "lora",
    "fallback_enabled": true,
    "fallback_type": "wifi",
    "retry_attempts": 3,
    "retry_delay": 2000,
    "ack_timeout": 5000
  },
  
  "i2c": {
    "id": 0,
    "sda": 21,
    "scl": 22,
    "freq": 400000
  },
  
  "sensors": [
    {
      "type": "dht22",
      "name": "air_quality",
      "enabled": true,
      "pin": 27,
      "read_interval": 60,
      "retry_attempts": 3,
      "alerts": {
        "temperature": {
          "min": 5.0,
          "max": 40.0,
          "hysteresis": 2.0,
          "notify": true
        },
        "humidity": {
          "min": 20.0,
          "max": 80.0,
          "hysteresis": 5.0,
          "notify": true
        }
      },
      "codes": {
        "temperature": "TA",
        "humidity": "HA"
      }
    },
    {
      "type": "bh1750",
      "name": "light_sensor",
      "enabled": true,
      "bus": "i2c",
      "address": 0x23,
      "mode": "CONT_HIRES_1",
      "alerts": {
        "luminance": {
          "min": 100.0,
          "max": null,
          "notify": true
        }
      },
      "codes": {
        "luminance": "LX"
      }
    },
    {
      "type": "ds18b20",
      "name": "soil_temp",
      "enabled": true,
      "pin": 4,
      "resolution": 12,
      "alerts": {
        "temperature": {
          "min": -10.0,
          "max": 50.0,
          "notify": true
        }
      },
      "codes": {
        "temperature": "TS"
      }
    },
    {
      "type": "lm393",
      "name": "soil_moisture",
      "enabled": true,
      "pin": 35,
      "params": {
        "dry_value": 3500,
        "wet_value": 900,
        "samples": 10
      },
      "alerts": {
        "soil_moisture": {
          "min": 20.0,
          "max": null,
          "notify": true
        }
      },
      "codes": {
        "soil_moisture": "SM"
      }
    }
  ],
  
  "pairing": {
    "timeout_ms": 10000,
    "button_pin": 13,
    "led_pin": 2,
    "max_attempts": 5,
    "retry_delay": 3000
  },
  
  "alerts": {
    "global": {
      "notify_retry": 3,
      "notify_interval": 300,
      "led_indication": true,
      "sound_alarm": false
    },
    "thresholds": {
      "critical": {
        "temperature": 50.0,
        "humidity": 95.0
      }
    }
  },
  
  "power": {
    "sleep_interval": 300,
    "deep_sleep": false,
    "wakeup_pin": 0,
    "reset_duration_ms": 10000,
    "low_power_mode": true
  },
  
  "logging": {
    "level": "INFO",
    "console": true,
    "file": false,
    "max_size": 1024,
    "rotation": 3
  },
  
  "network": {
    "wifi": {
      "ssid": "my-wifi",
      "password": "secret",
      "timeout": 10000,
      "retry": 3
    },
    "mnt": {
      "enabled": false,
      "server": "iot.example.com",
      "port": 1883,
      "user": "device",
      "password": "password"
    }
  },
  
  "ota": {
    "enabled": false,
    "server": "update.example.com",
    "port": 80,
    "path": "/firmware",
    "interval": 86400
  }
}